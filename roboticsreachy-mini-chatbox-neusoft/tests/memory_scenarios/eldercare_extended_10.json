      "runner": "router",
      "turns": [
        {"role": "user", "text": "以后叫我张老师。"},
        {"role": "assistant", "text": "好的，张老师。"}
      ],
      "expect": {
        "profile_facts": [
          {"key": "preferred_name", "value": "张老师", "status": "active"}
