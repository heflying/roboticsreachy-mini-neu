# TTS 运行时配置
# 模型参数维护见 ../models.toml（相对于工作目录）

# 使用的模型名称（必须在 models.toml 中有对应条目）
TTS_MODEL=piper-huayan
#piper-chaowen
#piper-huayan
#piper-xiao_ya
#vits-icefall-aishell3
#vits-aishell3
#vits-melo-zh-en
#vits-hf-fanchen-C
#vits-hf-theresa
#vits-hf-eula
#kokoro-v1_0
#kokoro-v1_1
#matcha-icefall-zh-baker

# 语速 (可选，覆盖 models.toml 中的默认值)
# TTS_SPEED=1.0

# 说话人 ID (可选，覆盖 models.toml 中的默认值)
# TTS_SPEAKER_ID=0

# 输出目录 (可选，默认: result)
TTS_OUTPUT_DIR=result
